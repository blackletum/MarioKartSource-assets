"LightmappedGeneric"
{
	"$basetexture" "dev/water"
	"$color" "{4 12 18}"
	"$scale" "[1 1]"

	"$translucent" "1"

	"%compilewater" 1

	"$surfaceprop" "water"

	"$bottommaterial" "water/water_dark_blue_gray_dx70_under"

	"$bumpframe" "0"

	"$abovewater" 1	

	"$texoffset" "[0 0]"

	"$texscale" "0.5"

	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$basetexture"
			"animatedtextureframenumvar" "$frame"
			"animatedtextureframerate" 20.00
		}

		"TextureScroll"
		{
			"texturescrollvar" "$texoffset"
			"texturescrollrate" .025
			"texturescrollangle" 45.00
		}

		"TextureTransform"
		{
			"translateVar" "$texoffset"
			"scaleVar" "$texscale"
			"resultVar" "$basetexturetransform"
		}
	}
}
