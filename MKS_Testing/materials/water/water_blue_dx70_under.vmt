"LightmappedGeneric"
{
	"$basetexture" "dev/water"
	"$color" "{0 144 255}"
	"$scale" "[1 1]"

	"$translucent" "1"

	"%compilewater" 1

	"$surfaceprop" "water"

	"$bumpframe" "0"

	"$abovewater" 0

	"$texoffset" "[0 0]"

	"$texscale" "0.5"

	"$fogenable" 1
	"$fogcolor" "{209 230 255}"
	"$fogstart" 0
	"$fogend" 250


	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$basetexture"
			"animatedtextureframenumvar" "$frame"
			"animatedtextureframerate" 20.00
		}

		"TextureScroll"
		{
			"texturescrollvar" "$texoffset"
			"texturescrollrate" .025
			"texturescrollangle" 45.00
		}

		"TextureTransform"
		{
			"translateVar" "$texoffset"
			"scaleVar" "$texscale"
			"resultVar" "$basetexturetransform"
		}
	}
}
