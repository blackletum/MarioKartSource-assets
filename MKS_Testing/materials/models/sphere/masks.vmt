mn_PhongEx
{
	"$basetexture" 	"shared/gray75"
	"$bumpmap" 	"models/sphere/n_noise_h_noise"



	"$phong" 1
	"$PHONGEXPONENT" "10"
//	"$phongboost" "1.25"
	
	"$envmap" "env_cubemap"
	"$envmaptint" "[1 0.85 0]"
	"$envmapsaturation" "0.2"
	"$envmapmaskscale" "1.0"

	"$usephongcolortexture" 1	//specmaskscale is dicarded
	"$HxEM" "models/sphere/HxEM"	//RGB are now used for the spec colormasking
	

	"$model" 		1
}
