mn_PhongEx
{
	"$basetexture" 	"models\characters\playable\metalmario\char"
	"$bumpmap"	"models\characters\playable\metalmario\char_normal"
	"$surfaceprop" "metal"

	"$envmap" 		"models\characters\playable\metalmario\envmap"
	"$envmaptint" "[.5 .5 .5]"
	//"$envmapcontrast"  1
	"$envmapsaturation" "0"



	"$phong" 1
	"$PHONGEXPONENT" "8"
	//"$PHONGBOOST" "4"

	"$PHONGFRESNELRANGES" "[1 2 5]"
	//"$ENVMAPFRESNELRANGES" "[0 1 2]" //when using ps20 fallback this turns fresnel ON, 
					//but only the last param is used for refl. strength

	"$model" 		1
}
